#!/usr/bin/env python3

import json
import os
import subprocess
import sys


def parse_args(args: list[str]) -> tuple[str, int | None]:
    if not args:
        raise SystemExit(1)

    line: int | None = None

    if len(args) > 1 and args[0].isdigit():
        line = int(args[0])
        args = args[1:]

    if len(args) > 1 and args[-1].isdigit():
        line = int(args[-1])
        args = args[:-1]

    path = " ".join(args).strip()
    if not path:
        raise SystemExit(1)

    if not os.path.isabs(path):
        path = os.path.abspath(path)

    return path, line


def main() -> int:
    path, line = parse_args(sys.argv[1:])

    if not os.environ.get("NVIM"):
        cmd = ["nvim"]
        if line is not None:
            cmd.append(f"+{line}")
        cmd.extend(["--", path])
        os.execvp(cmd[0], cmd)

    lua = "require('config.lazygit_edit').open(_A[1], _A[2])"
    arg2 = "v:null" if line is None else str(line)
    expr = f"luaeval({json.dumps(lua)}, [{json.dumps(path)}, {arg2}])"
    result = subprocess.run(
        ["nvim", "--server", os.environ["NVIM"], "--remote-expr", expr],
        stdout=subprocess.DEVNULL,
    )
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
