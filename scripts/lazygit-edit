#!/usr/bin/env python3

import json
import os
import subprocess
import sys


def parse_args(args: list[str]) -> tuple[str, int | None, bool]:
    if not args:
        raise SystemExit(1)

    open_in_tab = False
    if args[0] == "--tab":
        open_in_tab = True
        args = args[1:]

    if not args:
        raise SystemExit(1)

    line: int | None = None

    if len(args) > 1 and args[0].isdigit():
        line = int(args[0])
        args = args[1:]

    if len(args) > 1 and args[-1].isdigit():
        line = int(args[-1])
        args = args[:-1]

    path = " ".join(args).strip()
    if not path:
        raise SystemExit(1)

    if not os.path.isabs(path):
        path = os.path.abspath(path)

    return path, line, open_in_tab


def remote_expr(server: str, expr: str, *, capture: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["nvim", "--server", server, "--remote-expr", expr],
        stdout=subprocess.PIPE if capture else subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        text=True,
    )


def main() -> int:
    path, line, open_in_tab = parse_args(sys.argv[1:])

    if not os.environ.get("NVIM"):
        cmd = ["nvim"]
        if line is not None:
            cmd.append(f"+{line}")
        cmd.extend(["--", path])
        os.execvp(cmd[0], cmd)

    server = os.environ["NVIM"]
    lua_function = "open" if open_in_tab else "open_same_tab"
    lua = f"require('git.lazygit_edit').{lua_function}(_A[1], _A[2])"
    arg2 = "v:null" if line is None else str(line)
    expr = f"luaeval({json.dumps(lua)}, [{json.dumps(path)}, {arg2}])"

    result = remote_expr(server, expr)
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
